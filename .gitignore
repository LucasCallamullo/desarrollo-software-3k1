# ============================================
# ARCHIVOS DE DEPENDENCIAS
# ============================================
# Directorio de dependencias (NUNCA se sube a Git)
node_modules/           

# ============================================
# ARCHIVOS DE BASE DE DATOS (SQLite)
# ============================================
# Base de datos
*.sqlite         
*.sqlite3             
*.db                   

# ============================================
# VARIABLES DE ENTORNO
# ============================================
# Variables de entorno (passwords, keys, secrets)
# EXCEPCIÓN: el archivo de ejemplo SÍ se sube
.env                    
.env.*               
!.env.example           

# ============================================
# CARPETAS DE PROOF / EVIDENCIAS
# ============================================
# Archivos de proofs/pruebas
0_proofs/             
proofs/           
proofs.*               
*.proof                 
*.evidence           

# ============================================
# ARCHIVOS DE LOGS
# ============================================
*.log               
logs/                
npm-debug.log*      
yarn-debug.log*      
yarn-error.log*      
pm2-*.log           

# ============================================
# ARCHIVOS DEL SISTEMA OPERATIVO
# ============================================
.DS_Store             
Thumbs.db            
desktop.ini         
ehthumbs.db            
*.swp                  
*.swo                   

# ============================================
# EDITORES Y ENTORNOS DE DESARROLLO
# ============================================
.vscode/               
.idea/                 
*.suo                  
*.ntvs*            
*.njsproj*            
.vscode-test/       

# ============================================
# ARCHIVOS DE COBERTURA (TESTS)
# ============================================
coverage/               
.nyc_output/        
*.lcov              

# ============================================
# ARCHIVOS COMPILADOS / BUILD
# ============================================
dist/                
build/               
out/                 
*.tsbuildinfo        

# ============================================
# ARCHIVOS TEMPORALES Y DE CACHE
# ============================================
.cache/                
tmp/              
temp/
*.tmp
*.temp

# ============================================
# DEPENDENCIAS ESPECÍFICAS DE FRAMEWORKS
# ============================================
.sass-cache/            
.parcel-cache/      
.next/               
.nuxt/               
.vercel/               
.netlify/           

# ============================================
# ARCHIVOS DE MÓDULOS NODE (avanzados)
# ============================================
package-lock.json
jsonconfig.json
yarn.lock             
pnpm-lock.yaml        
# NOTA: Los archivos lock SÍ suelen subirse en proyectos serios para garantizar 
# reproducibilidad. Solo ignóralos si trabajas en equipos que prefieren no hacerlo.

# ============================================
# ARCHIVOS SUBIDOS POR EL USUARIO (opcional)
# ============================================
uploads/              
attachments/        
downloads/           